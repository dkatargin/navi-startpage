{
  "manifest_version": 3,
  "name": "NAVI Startpage",
  "version": "0.1.0",
  "description": "Cyberpunk-styled personal startpage",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "bookmarks",
    "history",
    "storage"
  ]
}
